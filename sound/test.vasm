    section .text
;========================================================
; ROM HEADER
;========================================================

                org     $000000

                dc.l    $00FF0000          ; Initial SP
                dc.l    EntryPoint         ; Initial PC

                dcb.l   62,0               ; Remaining vectors


;========================================================
; ROM HEADER
;========================================================

                org     $000100

                dc.b    "SEGA GENESIS    "
                dc.b    "(C)CHATGPT2026  "
                dc.b    "Z80 PSG DEMO                         "
                dc.b    "Z80 PSG DEMO                         "
                dc.b    "GM 00000000-00"
                dc.w    0
                dc.b    "J               "

                dc.l    $000000
                dc.l    ROM_End-1

                dc.l    $00FF0000
                dc.l    $00FFFFFF

                dc.l    0,0

                dc.b    "            "

                dc.b    "JUE             "


;========================================================
; CONSTANTS
;========================================================

Z80_RAM        =     $A00000
Z80_BUSREQ     =     $A11100
Z80_RESET      =     $A11200

VERSION_REG    =     $A10001

Z80_COMMAND    =     Z80_RAM+$0400
Z80_SONG       =     Z80_RAM+$0500

CMD_STOP       =     2
CMD_PLAY       =     1


;========================================================
; ENTRY
;========================================================

EntryPoint:

                ; TMSS
                move.b  VERSION_REG,d0
                andi.b  #$0F,d0
                beq.s   .no_tmss

                move.l  #'SEGA',$A14000

.no_tmss:

                bsr     InitZ80

MainLoop:

                bsr     StartTone
                move.l  #$000FFFFF,d0
.delay1:
                subq.l  #1,d0
                bne.s   .delay1

                bsr     StopTone

                move.l  #$000FFFFF,d0
.delay2:
                subq.l  #1,d0
                bne.s   .delay2

                bra.s   MainLoop


;========================================================
; INIT Z80
;========================================================

InitZ80:

                move.w  #$0000,Z80_RESET                    ; assert reset
                move.w  #$0100,Z80_BUSREQ                   ; request bus
                move.w  #$0100,Z80_RESET                    ; release reset

                lea     Z80Program(pc),a0
                lea     Z80_RAM,a1

                move.w  #(Z80ProgramEnd-Z80Program)-1,d0
.copy:
                move.b  (a0)+,(a1)+
                dbra    d0,.copy

                lea     song_start,a0
                lea     Z80_SONG,a1
                move.w  #(song_end-song_start)-1,d0
.copysong:      move.b  (a0)+,(a1)+
                dbra    d0,.copysong

                move.w  #$0000,Z80_RESET                    ; assert reset and wait for a bit
                move.w  #20, d0
.1:             dbra    d0,.1                

                move.w  #$0100,Z80_RESET                    ; release reset
                move.w  #$0000,Z80_BUSREQ                   ; release bus

                rts


;========================================================
; COMMANDS
;========================================================

StartTone:
                move.w  #$100, Z80_BUSREQ

.1:             btst    #0, Z80_BUSREQ
                bne.s   .1

                move.b  #CMD_PLAY,Z80_COMMAND

                move.w  #$0000,Z80_BUSREQ                   ; release bus
                rts


StopTone:
                move.w  #$100, Z80_BUSREQ

.1:             btst    #0, Z80_BUSREQ
                bne.s   .1

                move.b  #CMD_STOP,Z80_COMMAND

                move.w  #$0000,Z80_BUSREQ                   ; release bus
                rts


;========================================================
; Z80 PROGRAM
;========================================================

Z80Program:
    incbin "z80.bin"
Z80ProgramEnd:
    align(2)

